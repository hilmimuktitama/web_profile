---
import "../styles/global.css";
import { withBase } from "../lib/urls";

interface Props {
  title?: string;
  description?: string;
  showContactFooter?: boolean;
}

const {
  title = "Hilmi Muktitama",
  description = "Senior Technical Program Manager focused on B2B SaaS platform delivery, customer data, AI automation, rollout readiness, and source-backed program execution.",
  showContactFooter = true
} = Astro.props;

const pageTitle = title === "Hilmi Muktitama" ? title : `${title} | Hilmi Muktitama`;
const site = Astro.site ?? new URL("https://hilmimuktitama.github.io");
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const shareImageUrl = new URL(withBase("/og-image.png"), site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={shareImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase("/")} aria-label="Hilmi Muktitama home">
          <span class="brand-mark">HM</span>
          <span>Hilmi Muktitama</span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href={withBase("/resume/")}>Resume</a>
          <a href={withBase("/#case-studies")}>Case Studies</a>
          <a href={withBase("/articles/")}>Writing</a>
          <a href={withBase("/contact/")}>Contact</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      {showContactFooter && (
        <footer class="site-footer" id="contact">
          <div>
            <p class="footer-title">Contact</p>
            <p class="muted">Open to roles where program/product delivery matters to you and you need someone who can help move the work forward.</p>
          </div>
          <div class="footer-links" aria-label="Contact links">
            <a href="mailto:hilmimukti@gmail.com">hilmimukti@gmail.com</a>
            <a href="https://www.linkedin.com/in/hilmimuktitama/">LinkedIn</a>
            <a href="https://github.com/hilmimuktitama">GitHub</a>
          </div>
        </footer>
      )}
    </div>
  </body>
</html>
