---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/urls";

export async function getStaticPaths() {
  const now = Date.now();
  const articles = (await getCollection("articles")).filter(
    (article) => article.data.pubDate.valueOf() <= now
  );
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const formattedDate = article.data.pubDate.toLocaleDateString("en", {
  day: "2-digit",
  month: "short",
  year: "numeric"
});
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <article class="article-page">
    <header>
      <a href={withBase("/articles/")}>Writing</a>
      <p class="meta">{formattedDate}</p>
      <h1>{article.data.title}</h1>
      <p class="lede">{article.data.description}</p>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
