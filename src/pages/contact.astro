---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Contact Hilmi Muktitama for Senior Technical Program Manager roles across program and product delivery, platform work, and AI automation readiness."
  showContactFooter={false}
>
  <section class="section contact-page" aria-labelledby="contact-title">
    <div class="section-heading">
      <p class="eyebrow">Contact</p>
      <div>
        <h1 id="contact-title">Let's talk about program and product delivery work.</h1>
        <p>Open to roles where program/product delivery matters and you need someone who can help move the work forward.</p>
      </div>
    </div>

    <div class="contact-method-grid" aria-label="Contact methods">
      <a class="contact-method primary" href="mailto:hilmimukti@gmail.com">
        <span>Email</span>
        <strong>hilmimukti@gmail.com</strong>
      </a>
      <a class="contact-method" href="https://www.linkedin.com/in/hilmimuktitama/">
        <span>LinkedIn</span>
        <strong>linkedin.com/in/hilmimuktitama</strong>
      </a>
      <a class="contact-method" href="https://github.com/hilmimuktitama">
        <span>GitHub</span>
        <strong>github.com/hilmimuktitama</strong>
      </a>
    </div>
  </section>
</BaseLayout>
