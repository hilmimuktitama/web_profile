---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/urls";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.status === "public")
  .sort((a, b) => a.data.order - b.data.order);
const visibleProjects = projects.slice(0, 3);

const now = Date.now();

const articles = (await getCollection("articles"))
  .filter((article) => article.data.pubDate.valueOf() <= now)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const resumeEntries = (await getCollection("resume")).sort((a, b) => a.data.order - b.data.order);
const experience = resumeEntries.filter((entry) => entry.data.section === "experience");
const highlightedExperience = experience.slice(0, 2);

const formatDate = (date?: Date) =>
  date?.toLocaleDateString("en", { month: "short", year: "numeric" }) ?? "Ready for update";
---

<BaseLayout>
  <section class="section hero" aria-labelledby="hero-title">
    <div class="hero-identity">
      <h1 id="hero-title"><span>Hilmi</span><span>Muktitama</span></h1>
      <div class="hero-meta" aria-label="Profile metadata">
        <span>TPM dossier</span>
        <span>Execution systems</span>
        <span>Evidence-led updates</span>
      </div>
    </div>
    <div class="hero-copy">
      <p class="role-title">Technical Program Manager</p>
      <p class="lede">
        I help software teams turn delivery complexity into source-backed plans, visible blockers, and stakeholder-ready program updates.
      </p>
      <div class="link-row" aria-label="Primary profile links">
        <a class="button-link primary" href={withBase("/#contact")}>Contact</a>
        <a class="button-link" href={withBase("/resume/")}>Resume</a>
        <a class="button-link" href="https://www.linkedin.com/in/hilmimuktitama/">LinkedIn</a>
        <a class="button-link" href="https://github.com/hilmimuktitama">GitHub</a>
      </div>
    </div>
  </section>

  <section class="section" id="resume" aria-labelledby="resume-title">
    <div class="section-heading">
      <p class="eyebrow">Resume</p>
      <div>
        <h2 id="resume-title">TPM experience across delivery, product, and QA.</h2>
        <p>Five-plus years moving from quality assurance into product work and technical program leadership, with a focus on planning, risk visibility, and cross-functional execution.</p>
      </div>
    </div>
    <div class="row-list">
      {highlightedExperience.map((entry) => (
        <article class="content-row">
          <p class="meta">{entry.data.period ?? "Selected work"}</p>
          <div>
            <h3>{entry.data.title}</h3>
            {entry.data.organization && <p class="meta">{entry.data.organization}</p>}
            <p>{entry.data.summary}</p>
            {entry.data.items.length > 0 && (
              <ul class="evidence-list">
                {entry.data.items.slice(0, 3).map((item) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="case-studies" aria-labelledby="case-studies-title">
    <div class="section-heading">
      <p class="eyebrow">Selected Work</p>
      <div>
        <h2 id="case-studies-title">Selected work on delivery visibility, planning quality, and source-backed reporting.</h2>
        <p>Public project notes that show how I think about execution systems without exposing internal materials, client details, or sensitive metrics.</p>
      </div>
    </div>
    <div class="row-list">
      {visibleProjects.map((project) => (
        <article class={`project-row ${project.data.featured ? "featured" : ""}`}>
          <div>
            <a class="project-title" href={project.data.repoUrl ?? withBase(`/work/${project.slug}/`)}>
              {project.data.title}
            </a>
          </div>
          <p class="project-desc">{project.data.description}</p>
          <div class="project-actions">
            <span class="meta">{formatDate(project.data.updatedDate)}</span>
            <a href={withBase(`/work/${project.slug}/`)}>Read notes</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="articles" aria-labelledby="articles-title">
    <div class="section-heading">
      <p class="eyebrow">Writing</p>
      <div>
        <h2 id="articles-title">Writing on software work, AI, and execution.</h2>
        <p>Personal notes on building with AI, technical work, and the operating habits behind software delivery.</p>
      </div>
    </div>
    {articles.length > 0 ? (
      <div class="article-grid">
        {articles.map((article) => (
          <a class="article-card" href={withBase(`/articles/${article.slug}/`)}>
            <p class="meta">{formatDate(article.data.pubDate)}</p>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-note">Writing will appear here once there is something useful to share.</p>
    )}
  </section>
</BaseLayout>
