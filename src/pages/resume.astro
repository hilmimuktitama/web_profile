---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { GITHUB_URL, LINKEDIN_URL } from "../lib/urls";

const entries = (await getCollection("resume")).sort((a, b) => a.data.order - b.data.order);
const experience = entries.filter((entry) => entry.data.section === "experience");
const skills = entries.filter((entry) => entry.data.section === "skill");
const education = entries.filter((entry) => entry.data.section === "education");
const certifications = entries.filter((entry) => entry.data.section === "certification");
---

<BaseLayout
  title="Resume"
  description="Resume for Hilmi Muktitama, Senior Technical Program Manager at Mekari with experience across B2B SaaS platform delivery, customer data, AI automation, product management, and QA engineering."
>
  <article class="resume-page">
    <header class="resume-hero">
      <p class="eyebrow">Resume</p>
      <div>
        <h1>Hilmi Muktitama</h1>
        <p class="role-title">Senior Technical Program Manager</p>
        <p class="lede">
          Senior TPM at Mekari with 5+ years across program management, product management, and QA engineering, currently leading cross-squad B2B SaaS platform and automation programs.
        </p>
        <div class="resume-contact" aria-label="Public resume contact links">
          <a href={LINKEDIN_URL}>LinkedIn</a>
          <a href={GITHUB_URL}>GitHub</a>
        </div>
      </div>
    </header>

    <section class="resume-section" aria-labelledby="experience-title">
      <div class="resume-section-heading">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">Work history</h2>
      </div>
      <div class="resume-timeline">
        {experience.map((entry) => (
          <article class="resume-role">
            <div class="resume-role-meta">
              <p>{entry.data.period}</p>
              {entry.data.location && <p>{entry.data.location}</p>}
            </div>
            <div>
              <h3>{entry.data.title}</h3>
              {entry.data.organization && <p class="resume-org">{entry.data.organization}</p>}
              <p>{entry.data.summary}</p>
              {entry.data.items.length > 0 && (
                <ul class="resume-bullets">
                  {entry.data.items.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="resume-section resume-grid-section" aria-labelledby="credentials-title">
      <div class="resume-section-heading">
        <p class="eyebrow">Credentials</p>
        <h2 id="credentials-title">Skills, education, and certifications</h2>
      </div>
      <div class="resume-grid">
        <section class="resume-card" aria-labelledby="skills-title">
          <h3 id="skills-title">Top skills</h3>
          {skills.map((entry) => (
            <div>
              <p>{entry.data.summary}</p>
              <div class="tag-row">
                {entry.data.items.map((item) => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </section>

        <section class="resume-card" aria-labelledby="education-title">
          <h3 id="education-title">Education</h3>
          {education.map((entry) => (
            <div class="credential-item">
              <p class="credential-title">{entry.data.title}</p>
              {entry.data.organization && <p>{entry.data.organization}</p>}
              {entry.data.period && <p class="meta">{entry.data.period}</p>}
              <p>{entry.data.summary}</p>
              {entry.data.items.length > 0 && (
                <ul class="credential-list">
                  {entry.data.items.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>
          ))}
        </section>

        <section class="resume-card" aria-labelledby="certifications-title">
          <h3 id="certifications-title">Certifications</h3>
          {certifications.map((entry) => (
            <div class="credential-item">
              <p class="credential-title">{entry.data.title}</p>
              {entry.data.summary && <p>{entry.data.summary}</p>}
              {entry.data.items.length > 0 && (
                <ul class="credential-list">
                  {entry.data.items.map((item) => <li>{item}</li>)}
                </ul>
              )}
            </div>
          ))}
        </section>
      </div>
    </section>
  </article>
</BaseLayout>
