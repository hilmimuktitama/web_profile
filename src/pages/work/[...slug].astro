---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/urls";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).filter(
    (project) => project.data.status !== "draft"
  );
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const formatProjectStatus = (status: string) =>
  status === "public" ? "public repo" : "case note";
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="article-page">
    <header>
      <a href={withBase("/work/")}>Case Studies</a>
      <p class="meta" style="margin-top: 18px;">{formatProjectStatus(project.data.status)}</p>
      <h1>{project.data.title}</h1>
      <p class="lede" style="margin-top: 18px;">{project.data.description}</p>
      <div class="link-row" style="margin-top: 22px;">
        {project.data.repoUrl && <a class="button-link" href={project.data.repoUrl}>Repository</a>}
        {project.data.liveUrl && <a class="button-link" href={project.data.liveUrl}>Live site</a>}
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
